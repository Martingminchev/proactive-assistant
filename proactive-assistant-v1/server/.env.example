PORT=3001
MONGODB_URI=mongodb://localhost:27017/proactive-assistant
NEWS_API_KEY=your_newsapi_key_here

# AI Provider Configuration
# Options: zai, gemini, pieces
AI_PROVIDER=zai

# z.ai Configuration (GLM-4.7)
# Get your API key from: https://z.ai/manage-apikey/apikey-list
ZAI_API_KEY=your_zai_api_key_here
ZAI_MODEL=glm-4.7

# Google Gemini Configuration
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Pieces OS Configuration
PIECES_PORT=39300

# Optional: Use Pieces to pre-summarize context before sending to AI
USE_PIECES_SUMMARY=false
