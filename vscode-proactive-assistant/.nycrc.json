{
  "extends": "@istanbuljs/nyc-config-typescript",
  "all": true,
  "check-coverage": true,
  "lines": 80,
  "statements": 80,
  "functions": 80,
  "branches": 80,
  "include": [
    "out/**/*.js"
  ],
  "exclude": [
    "out/test/**/*",
    "out/**/*.test.js",
    "out/test/runTest.js",
    "out/test/suite/index.js",
    "src/test/**/*",
    "**/*.d.ts"
  ],
  "reporter": [
    "text",
    "text-summary",
    "lcov",
    "html"
  ],
  "report-dir": "./coverage",
  "temp-dir": "./.nyc_output",
  "sourceMap": true,
  "instrument": true
}
